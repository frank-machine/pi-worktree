{
  "name": "@rezamonangg/pi-worktree",
  "version": "0.1.2",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rezamonangg/pi-worktree.git"
  },
  "bugs": {
    "url": "https://github.com/rezamonangg/pi-worktree/issues"
  },
  "homepage": "https://github.com/rezamonangg/pi-worktree#readme",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "keywords": ["pi-package", "pi", "worktree"],
  "description": "Pi package that routes agent file and shell work into an isolated git worktree.",
  "pi": {
    "extensions": ["./extensions/index.ts"],
    "skills": ["./skills"]
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "node --test --import tsx extensions/*.test.ts"
  },
  "devDependencies": {
    "@types/node": "latest",
    "tsx": "latest",
    "typescript": "latest"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  }
}
